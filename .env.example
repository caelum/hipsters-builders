# Resend API key for newsletter subscriptions
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Resend audience ID (created automatically on first subscribe if not set)
# Find at https://resend.com/audiences
RESEND_AUDIENCE_ID=

# From email for welcome and newsletter emails
# Requires a verified domain in Resend. Falls back to onboarding@resend.dev
RESEND_FROM_EMAIL=Hipsters Builders <newsletter@hipsters.builders>
