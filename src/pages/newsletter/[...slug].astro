---
import { getCollection, render } from 'astro:content';
import EditorialLayout from '../../layouts/EditorialLayout.astro';

export async function getStaticPaths() {
  const newsletters = await getCollection('newsletters');
  return newsletters.map(nl => ({ params: { slug: nl.id }, props: { newsletter: nl } }));
}

const { newsletter } = Astro.props;
const { Content } = await render(newsletter);
const { subject, editionNumber, pubDate } = newsletter.data;
const dateStr = new Date(pubDate).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
---

<EditorialLayout title={`Newsletter #${editionNumber}: ${subject}`} activeNav="newsletter">
  <article class="nl-detail">
    <header class="nl-detail__header">
      <div class="nl-detail__meta">
        <span class="nl-detail__edition">Edicao {editionNumber}</span>
        <span class="nl-detail__sep" aria-hidden="true">&middot;</span>
        <time class="nl-detail__date" datetime={new Date(pubDate).toISOString()}>{dateStr}</time>
      </div>
      <h1 class="nl-detail__title">{subject}</h1>
    </header>

    <div class="ed-prose">
      <Content />
    </div>

    <nav class="nl-detail__back">
      <a href="/newsletter" class="nl-detail__back-link">
        <svg class="nl-detail__back-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Todas as edicoes
      </a>
    </nav>
  </article>
</EditorialLayout>

<style>
  .nl-detail {
    max-width: 42rem;
    margin: 0 auto;
  }

  /* --- Header --- */
  .nl-detail__header {
    padding: 1rem 0 2.5rem;
  }

  .nl-detail__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .nl-detail__edition {
    font-family: var(--ed-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ed-accent);
  }

  .nl-detail__sep {
    color: var(--ed-ink-faint);
    font-size: 0.75rem;
  }

  .nl-detail__date {
    font-family: var(--ed-sans);
    font-size: 0.75rem;
    color: var(--ed-ink-muted);
    font-variant-numeric: tabular-nums;
  }

  .nl-detail__title {
    font-family: var(--ed-serif);
    font-size: clamp(1.75rem, 4.5vw, 2.5rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ed-ink);
  }

  /* --- Back navigation --- */
  .nl-detail__back {
    margin-top: 3rem;
    padding-top: 2rem;
  }

  .nl-detail__back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: var(--ed-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--ed-ink-muted);
    transition: color 0.15s;
  }

  .nl-detail__back-link:hover {
    color: var(--ed-accent);
  }

  .nl-detail__back-icon {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
  }
</style>
