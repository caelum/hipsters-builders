---
import { getCollection } from 'astro:content';
import EditorialLayout from '../../layouts/EditorialLayout.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';

const newsletters = (await getCollection('newsletters'))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

function formatDate(date: Date): string {
  return new Date(date).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
}
---

<EditorialLayout title="Newsletter" description="Arquivo da newsletter Hipsters Builders" activeNav="newsletter">

  <!-- Page header -->
  <header class="nl-header">
    <h1 class="nl-title">Newsletter</h1>
    <p class="nl-deck">
      Resumo semanal curado dos melhores episodios e discussoes da comunidade.
      Direto no seu e-mail, sem ruido.
    </p>
  </header>

  <!-- Subscribe -->
  <section class="nl-subscribe">
    <div class="nl-subscribe__inner">
      <p class="nl-subscribe__lead">Receba toda semana</p>
      <NewsletterForm />
    </div>
  </section>

  <!-- Archive -->
  {newsletters.length > 0 && (
    <section class="nl-archive">
      <div class="nl-archive__label">
        <svg class="nl-archive__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        Edicoes anteriores
      </div>
      <ol class="nl-list">
        {newsletters.map(nl => (
          <li class="nl-item">
            <a href={`/newsletter/${nl.id}`} class="nl-item__link">
              <span class="nl-item__number">{nl.data.editionNumber}</span>
              <span class="nl-item__content">
                <span class="nl-item__subject">{nl.data.subject}</span>
                <time class="nl-item__date" datetime={new Date(nl.data.pubDate).toISOString()}>
                  {formatDate(nl.data.pubDate)}
                </time>
              </span>
            </a>
          </li>
        ))}
      </ol>
    </section>
  )}

  {newsletters.length === 0 && (
    <section class="nl-empty">
      <p class="nl-empty__text">Nenhuma edicao publicada ainda.</p>
      <p class="nl-empty__hint">Assine acima para receber a primeira direto no seu e-mail.</p>
    </section>
  )}

</EditorialLayout>

<style>
  /* --- Page header --- */
  .nl-header {
    max-width: 38rem;
    padding: 1rem 0 2rem;
  }

  .nl-title {
    font-family: var(--ed-serif);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--ed-ink);
    margin-bottom: 0.75rem;
  }

  .nl-deck {
    font-family: var(--ed-serif);
    font-size: clamp(1rem, 2vw, 1.125rem);
    line-height: 1.6;
    color: var(--ed-ink-secondary);
  }

  /* --- Subscribe section --- */
  .nl-subscribe {
    max-width: 38rem;
    margin-bottom: 3.5rem;
  }

  .nl-subscribe__inner {
    background: var(--ed-bg-warm);
    padding: 2rem;
  }

  .nl-subscribe__lead {
    font-family: var(--ed-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ed-ink-muted);
    margin-bottom: 1rem;
  }

  /* --- Archive --- */
  .nl-archive {
    max-width: 38rem;
  }

  .nl-archive__label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--ed-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ed-ink-muted);
    margin-bottom: 1.5rem;
  }

  .nl-archive__icon {
    width: 1rem;
    height: 1rem;
    opacity: 0.5;
  }

  .nl-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .nl-item {
    /* whitespace separates, not borders */
  }

  .nl-item__link {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    padding: 1.25rem 0;
    transition: none;
  }

  .nl-item + .nl-item {
    border-top: 1px solid var(--ed-rule);
  }

  .nl-item__link:hover {
    color: inherit;
  }

  .nl-item__number {
    font-family: var(--ed-sans);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--ed-ink-faint);
    letter-spacing: 0.02em;
    min-width: 1.5rem;
    flex-shrink: 0;
  }

  .nl-item__content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .nl-item__subject {
    font-family: var(--ed-serif);
    font-size: clamp(1rem, 2vw, 1.125rem);
    font-weight: 600;
    line-height: 1.35;
    color: var(--ed-ink);
    transition: color 0.15s;
  }

  .nl-item__link:hover .nl-item__subject {
    color: var(--ed-accent);
  }

  .nl-item__date {
    font-family: var(--ed-sans);
    font-size: 0.75rem;
    color: var(--ed-ink-muted);
    font-variant-numeric: tabular-nums;
  }

  /* --- Empty state --- */
  .nl-empty {
    max-width: 38rem;
    padding: 4rem 0;
  }

  .nl-empty__text {
    font-family: var(--ed-serif);
    font-size: 1.125rem;
    color: var(--ed-ink-secondary);
    margin-bottom: 0.5rem;
  }

  .nl-empty__hint {
    font-family: var(--ed-sans);
    font-size: 0.8125rem;
    color: var(--ed-ink-muted);
  }
</style>
