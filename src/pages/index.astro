---
import BaseLayout from '../layouts/BaseLayout.astro';

const designs = [
  {
    name: 'V1 "Editorial"',
    href: '/design/v1',
    description: 'Fundo claro, tipografia serif, hierarquia jornalistica',
    style: 'light',
    colors: { bg: '#faf9f7', accent: '#c4342d', text: '#1a1a1a' },
  },
  {
    name: 'V2 "Linear"',
    href: '/design/v2',
    description: 'Dark refinado, episodios em lista, ultra-minimal',
    style: 'dark-cool',
    colors: { bg: '#0f0f13', accent: '#818cf8', text: '#f0f0f5' },
  },
  {
    name: 'V3 "Magazine"',
    href: '/design/v3',
    description: 'Dark quente, carrosseis horizontais, streaming-inspired',
    style: 'dark-warm',
    colors: { bg: '#1a1412', accent: '#f59e0b', text: '#f5f0eb' },
  },
];
---

<BaseLayout title="Design Prototypes">
  <Fragment slot="nav" />
  <Fragment slot="footer" />

  <div class="gallery">
    <header class="gallery__header">
      <h1 class="gallery__title">
        Hipsters<span class="gallery__dot">.</span>builders
      </h1>
      <p class="gallery__subtitle">Design Prototypes</p>
    </header>

    <div class="gallery__grid">
      {designs.map((d) => (
        <a href={d.href} class="card" style={`--card-bg: ${d.colors.bg}; --card-accent: ${d.colors.accent}; --card-text: ${d.colors.text};`}>
          <div class="card__preview">
            <div class="card__preview-bar" />
            <div class="card__preview-lines">
              <div class="card__preview-line card__preview-line--title" />
              <div class="card__preview-line card__preview-line--short" />
              <div class="card__preview-line card__preview-line--medium" />
            </div>
          </div>
          <div class="card__body">
            <h2 class="card__name">{d.name}</h2>
            <p class="card__desc">{d.description}</p>
          </div>
          <div class="card__arrow">&rarr;</div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  :global(html),
  :global(body) {
    background: #18181b !important;
    color: #e4e4e7 !important;
  }

  :global(body > main) {
    max-width: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  :global(a) {
    color: inherit;
    text-decoration: none;
  }

  .gallery {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
  }

  .gallery__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .gallery__title {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #f4f4f5;
  }

  .gallery__dot {
    color: #818cf8;
  }

  .gallery__subtitle {
    font-size: 0.875rem;
    color: #71717a;
    margin-top: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 500;
  }

  .gallery__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    width: 100%;
    max-width: 64rem;
  }

  @media (min-width: 768px) {
    .gallery__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  .card {
    display: flex;
    flex-direction: column;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #27272a;
    background: #27272a;
    transition: border-color 0.2s, transform 0.2s;
    text-decoration: none !important;
    color: inherit !important;
  }

  .card:hover {
    border-color: #52525b;
    transform: translateY(-4px);
    color: inherit !important;
  }

  .card__preview {
    background: var(--card-bg);
    padding: 1.5rem;
    min-height: 10rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card__preview-bar {
    height: 3px;
    width: 100%;
    background: var(--card-accent);
    border-radius: 1px;
  }

  .card__preview-lines {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.5rem;
  }

  .card__preview-line {
    height: 8px;
    border-radius: 2px;
    background: var(--card-text);
    opacity: 0.15;
  }

  .card__preview-line--title {
    width: 70%;
    height: 12px;
    opacity: 0.3;
  }

  .card__preview-line--short {
    width: 45%;
  }

  .card__preview-line--medium {
    width: 60%;
  }

  .card__body {
    padding: 1.25rem 1.5rem;
    flex: 1;
  }

  .card__name {
    font-size: 1.125rem;
    font-weight: 600;
    color: #f4f4f5;
    margin-bottom: 0.375rem;
  }

  .card__desc {
    font-size: 0.8125rem;
    color: #a1a1aa;
    line-height: 1.5;
  }

  .card__arrow {
    padding: 0 1.5rem 1.25rem;
    font-size: 1.25rem;
    color: #52525b;
    transition: color 0.2s, transform 0.2s;
  }

  .card:hover .card__arrow {
    color: #818cf8;
    transform: translateX(4px);
  }
</style>
