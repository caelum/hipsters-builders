---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { mockEpisodes, mockCurtas } from '../../data/mock';

const rawEpisodes = await getCollection('episodes');
const rawCurtas = await getCollection('curtas');

const episodes = (rawEpisodes.length > 0 ? rawEpisodes : mockEpisodes)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const curtas = (rawCurtas.length > 0 ? rawCurtas : mockCurtas)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const featured = episodes[0];
const recentEpisodes = episodes.slice(1, 13);
const recentCurtas = curtas.slice(0, 6);

function formatDate(date: Date): string {
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' });
}

function podcastShort(podcast: string): string {
  const map: Record<string, string> = {
    'Hipsters Ponto Tech': 'Hipsters',
    'IA Sob Controle': 'IA Sob Controle',
    'Like a Boss': 'Like a Boss',
    'Mesa de Produto': 'Mesa de Produto',
    'Carreira Sem Fronteiras': 'Carreira SF',
  };
  return map[podcast] || podcast;
}
---

<BaseLayout title="v2 — Linear">
  <Fragment slot="nav">
    <nav class="v2-nav">
      <div class="v2-nav-inner">
        <a href="/design/v2" class="v2-wordmark">hipsters<span class="v2-dot">.</span>builders</a>
        <div class="v2-nav-links">
          <a href="#episodes">Episodios</a>
          <a href="#curtas">Curtas</a>
          <a href="#newsletter">Newsletter</a>
        </div>
      </div>
    </nav>
  </Fragment>

  <!-- Featured -->
  <section class="v2-featured">
    <div class="v2-label-row">
      <span class="v2-label">Ultimo episodio</span>
      <time class="v2-label-date">{formatDate(featured.data.pubDate)}</time>
    </div>
    <a href={`/episodios/${featured.id}`} class="v2-featured-link">
      <h1 class="v2-featured-title">{featured.data.title}</h1>
    </a>
    <div class="v2-featured-meta">
      <span class="v2-featured-podcast">{podcastShort(featured.data.podcast)}{featured.data.episodeNumber ? ` #${featured.data.episodeNumber}` : ''}</span>
      {featured.data.duration && (
        <span class="v2-featured-duration">{featured.data.duration}</span>
      )}
      <span class="v2-featured-authors">{featured.data.authors.join(', ')}</span>
    </div>
    <p class="v2-featured-desc">{featured.data.description}</p>
    {featured.data.quotes.length > 0 && (
      <blockquote class="v2-featured-quote">
        <p>{featured.data.quotes[0].text}</p>
        <footer>
          <span class="v2-quote-speaker">{featured.data.quotes[0].speaker}</span>
          {featured.data.quotes[0].timestamp && (
            <span class="v2-quote-time">{featured.data.quotes[0].timestamp}</span>
          )}
        </footer>
      </blockquote>
    )}
  </section>

  <!-- Episodes -->
  <section id="episodes" class="v2-section">
    <div class="v2-section-header">
      <h2 class="v2-section-title">Episodios</h2>
      <span class="v2-section-count">{episodes.length}</span>
    </div>

    <div class="v2-list" role="list">
      <div class="v2-list-head" aria-hidden="true">
        <span class="v2-col-num">#</span>
        <span class="v2-col-title">Titulo</span>
        <span class="v2-col-podcast">Podcast</span>
        <span class="v2-col-date">Data</span>
      </div>
      {recentEpisodes.map((ep) => (
        <a href={`/episodios/${ep.id}`} class="v2-row" role="listitem">
          <span class="v2-col-num">{ep.data.episodeNumber || ''}</span>
          <span class="v2-col-title">
            <span class="v2-row-title">{ep.data.title}</span>
            <span class="v2-row-tags">
              {ep.data.tags.slice(0, 3).map(tag => (
                <span class="v2-tag">{tag}</span>
              ))}
            </span>
          </span>
          <span class="v2-col-podcast">{podcastShort(ep.data.podcast)}</span>
          <span class="v2-col-date">{formatDate(ep.data.pubDate)}</span>
        </a>
      ))}
    </div>

    <div class="v2-more">
      <a href="/episodios">Ver todos os {episodes.length} episodios</a>
    </div>
  </section>

  <!-- Curtas -->
  <section id="curtas" class="v2-section">
    <div class="v2-section-header">
      <h2 class="v2-section-title">Curtas</h2>
      <span class="v2-section-count">{curtas.length}</span>
    </div>

    <div class="v2-curtas">
      {recentCurtas.map((c) => (
        <article class="v2-curta">
          <blockquote class="v2-curta-quote">
            <p>{c.data.quote}</p>
          </blockquote>
          <footer class="v2-curta-footer">
            <span class="v2-curta-speaker">{c.data.speaker}</span>
            <span class="v2-curta-sep">/</span>
            <span class="v2-curta-context">{c.data.context}</span>
          </footer>
        </article>
      ))}
    </div>

    <div class="v2-more">
      <a href="/curtas">Ver todas as {curtas.length} curtas</a>
    </div>
  </section>

  <!-- Newsletter -->
  <section id="newsletter" class="v2-section v2-newsletter">
    <div class="v2-newsletter-inner">
      <h2 class="v2-newsletter-title">Newsletter semanal</h2>
      <p class="v2-newsletter-desc">Resumo curado toda quarta-feira. Sem spam, sem ruido.</p>
      <form class="v2-newsletter-form" action="/api/subscribe" method="POST">
        <input
          type="email"
          name="email"
          required
          placeholder="seu@email.com"
          class="v2-newsletter-input"
          autocomplete="email"
        />
        <button type="submit" class="v2-newsletter-btn">Assinar</button>
      </form>
      <p class="v2-newsletter-fine">Cancelamento em um clique. Seus dados seguros.</p>
    </div>
  </section>

  <!-- Footer -->
  <Fragment slot="footer">
    <footer class="v2-footer">
      <div class="v2-footer-inner">
        <span class="v2-footer-brand">hipsters.builders</span>
        <span class="v2-footer-sep">/</span>
        <a href="https://hipsters.tech" class="v2-footer-link">Hipsters Network</a>
        <span class="v2-footer-sep">/</span>
        <a href="https://alura.com.br" class="v2-footer-link">Alura</a>
      </div>
    </footer>
  </Fragment>
</BaseLayout>

<style>
  /* =============================================
     V2 — LINEAR
     Dark minimal. Vercel-inspired. Monochrome + indigo.
     ============================================= */

  /* ── Tokens ───────────────────────────────────── */

  :root {
    --v2-bg: #0a0a0f;
    --v2-surface: #0e0e14;
    --v2-border: rgba(255, 255, 255, 0.055);
    --v2-border-hover: rgba(255, 255, 255, 0.09);
    --v2-text-0: #ededf2;
    --v2-text-1: #c8c8d4;
    --v2-text-2: #7d7d90;
    --v2-text-3: #484860;
    --v2-accent: #818cf8;
    --v2-accent-soft: rgba(129, 140, 248, 0.08);
    --v2-accent-medium: rgba(129, 140, 248, 0.15);
    --v2-mono: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
    --v2-sans: 'Inter', system-ui, -apple-system, sans-serif;
    --v2-max: 920px;
  }

  /* ── Override body for this prototype ──────────── */

  :global(body) {
    background: var(--v2-bg) !important;
    color: var(--v2-text-1) !important;
    font-family: var(--v2-sans) !important;
    -webkit-font-smoothing: antialiased;
  }

  :global(main) {
    padding: 0 !important;
    max-width: none !important;
  }

  /* ── Nav ───────────────────────────────────────── */

  .v2-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    background: rgba(10, 10, 15, 0.8);
    border-bottom: 1px solid var(--v2-border);
  }

  .v2-nav-inner {
    max-width: var(--v2-max);
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .v2-wordmark {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--v2-text-2) !important;
    text-decoration: none !important;
    transition: color 0.2s;
  }

  .v2-wordmark:hover {
    color: var(--v2-text-0) !important;
  }

  .v2-dot {
    color: var(--v2-accent);
  }

  .v2-nav-links {
    display: flex;
    gap: 1.75rem;
  }

  .v2-nav-links a {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--v2-text-3) !important;
    text-decoration: none !important;
    letter-spacing: 0.01em;
    transition: color 0.2s;
  }

  .v2-nav-links a:hover {
    color: var(--v2-text-1) !important;
  }

  /* ── Layout ────────────────────────────────────── */

  .v2-section {
    max-width: var(--v2-max);
    margin: 0 auto;
    padding: 3rem 1.5rem;
    border-top: 1px solid var(--v2-border);
  }

  .v2-section-header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
  }

  .v2-section-title {
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--v2-text-3);
  }

  .v2-section-count {
    font-size: 0.625rem;
    font-family: var(--v2-mono);
    color: var(--v2-text-3);
    opacity: 0.5;
  }

  /* ── Featured ──────────────────────────────────── */

  .v2-featured {
    max-width: var(--v2-max);
    margin: 0 auto;
    padding: 5rem 1.5rem 3.5rem;
  }

  .v2-label-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .v2-label {
    font-size: 0.625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--v2-accent);
  }

  .v2-label-date {
    font-size: 0.625rem;
    font-family: var(--v2-mono);
    color: var(--v2-text-3);
    letter-spacing: 0.02em;
  }

  .v2-featured-link {
    text-decoration: none !important;
    display: block;
  }

  .v2-featured-title {
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.1;
    color: var(--v2-text-0);
    margin-bottom: 1.25rem;
    transition: color 0.2s;
    max-width: 42rem;
  }

  .v2-featured-link:hover .v2-featured-title {
    color: var(--v2-accent);
  }

  .v2-featured-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .v2-featured-podcast {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--v2-text-1);
  }

  .v2-featured-duration {
    font-size: 0.6875rem;
    font-family: var(--v2-mono);
    color: var(--v2-text-3);
  }

  .v2-featured-authors {
    font-size: 0.75rem;
    color: var(--v2-text-2);
    font-weight: 300;
  }

  .v2-featured-desc {
    font-size: 0.9375rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--v2-text-2);
    max-width: 38rem;
  }

  .v2-featured-quote {
    margin-top: 2rem;
    padding-left: 1rem;
    border-left: 1px solid var(--v2-accent-medium);
    max-width: 36rem;
  }

  .v2-featured-quote p {
    font-size: 0.875rem;
    font-weight: 300;
    font-style: italic;
    line-height: 1.7;
    color: var(--v2-text-1);
    margin: 0;
  }

  .v2-featured-quote footer {
    margin-top: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .v2-quote-speaker {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--v2-text-2);
    font-style: normal;
  }

  .v2-quote-time {
    font-size: 0.625rem;
    font-family: var(--v2-mono);
    color: var(--v2-text-3);
  }

  /* ── Episode List ──────────────────────────────── */

  .v2-list {
    display: flex;
    flex-direction: column;
  }

  .v2-list-head {
    display: none;
  }

  @media (min-width: 768px) {
    .v2-list-head {
      display: grid;
      grid-template-columns: 3rem 1fr 9rem 5.5rem;
      gap: 1rem;
      padding: 0 0 0.5rem;
      font-size: 0.625rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--v2-text-3);
      opacity: 0.6;
      border-bottom: 1px solid var(--v2-border);
    }
  }

  .v2-row {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem 0;
    text-decoration: none !important;
    border-bottom: 1px solid var(--v2-border);
    transition: border-color 0.2s;
  }

  .v2-row:first-of-type {
    border-top: none;
  }

  .v2-row:hover {
    border-bottom-color: var(--v2-border-hover);
  }

  .v2-row:hover .v2-row-title {
    color: var(--v2-text-0);
  }

  @media (min-width: 768px) {
    .v2-row {
      display: grid;
      grid-template-columns: 3rem 1fr 9rem 5.5rem;
      gap: 1rem;
      align-items: baseline;
      flex-direction: row;
    }
  }

  .v2-col-num {
    font-size: 0.6875rem;
    font-family: var(--v2-mono);
    color: var(--v2-text-3);
    opacity: 0.5;
    min-width: 3rem;
  }

  @media (max-width: 767px) {
    .v2-col-num {
      display: none;
    }
  }

  .v2-col-title {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .v2-row-title {
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--v2-text-1);
    line-height: 1.4;
    transition: color 0.2s;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 767px) {
    .v2-row-title {
      white-space: normal;
      font-weight: 450;
    }
  }

  .v2-row-tags {
    display: flex;
    gap: 0.375rem;
    overflow: hidden;
  }

  .v2-tag {
    font-size: 0.625rem;
    font-family: var(--v2-mono);
    color: var(--v2-text-3);
    opacity: 0.6;
    white-space: nowrap;
  }

  .v2-tag::before {
    content: '#';
    opacity: 0.4;
  }

  .v2-col-podcast {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--v2-text-2);
    white-space: nowrap;
  }

  @media (max-width: 767px) {
    .v2-col-podcast {
      font-size: 0.6875rem;
      color: var(--v2-accent);
      opacity: 0.7;
      order: -1;
    }
  }

  .v2-col-date {
    font-size: 0.6875rem;
    font-family: var(--v2-mono);
    color: var(--v2-text-3);
    white-space: nowrap;
    text-align: right;
  }

  @media (max-width: 767px) {
    .v2-col-date {
      display: none;
    }
  }

  .v2-more {
    margin-top: 1.5rem;
  }

  .v2-more a {
    font-size: 0.75rem;
    color: var(--v2-text-3) !important;
    text-decoration: none !important;
    transition: color 0.2s;
    letter-spacing: 0.01em;
  }

  .v2-more a:hover {
    color: var(--v2-accent) !important;
  }

  .v2-more a::after {
    content: ' \2192';
    opacity: 0.4;
    transition: opacity 0.2s;
  }

  .v2-more a:hover::after {
    opacity: 0.8;
  }

  /* ── Curtas ────────────────────────────────────── */

  .v2-curtas {
    display: flex;
    flex-direction: column;
  }

  .v2-curta {
    padding: 1.25rem 0 1.25rem 1rem;
    border-left: 1px solid var(--v2-border);
    border-bottom: 1px solid var(--v2-border);
    transition: border-left-color 0.2s;
  }

  .v2-curta:last-child {
    border-bottom: none;
  }

  .v2-curta:hover {
    border-left-color: var(--v2-accent-medium);
  }

  .v2-curta-quote {
    margin: 0;
  }

  .v2-curta-quote p {
    font-size: 0.875rem;
    font-weight: 300;
    line-height: 1.7;
    color: var(--v2-text-1);
    margin: 0;
    max-width: 40rem;
  }

  .v2-curta-footer {
    margin-top: 0.625rem;
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .v2-curta-speaker {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--v2-text-2);
  }

  .v2-curta-sep {
    font-size: 0.625rem;
    color: var(--v2-text-3);
    opacity: 0.3;
  }

  .v2-curta-context {
    font-size: 0.6875rem;
    font-weight: 300;
    color: var(--v2-text-3);
  }

  /* ── Newsletter ────────────────────────────────── */

  .v2-newsletter {
    padding-top: 3.5rem;
    padding-bottom: 5rem;
  }

  .v2-newsletter-inner {
    max-width: 26rem;
  }

  .v2-newsletter-title {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--v2-text-0);
    margin-bottom: 0.375rem;
  }

  .v2-newsletter-desc {
    font-size: 0.8125rem;
    font-weight: 300;
    color: var(--v2-text-2);
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  .v2-newsletter-form {
    display: flex;
    gap: 0;
    overflow: hidden;
    border: 1px solid var(--v2-border);
    border-radius: 6px;
    transition: border-color 0.2s;
  }

  .v2-newsletter-form:focus-within {
    border-color: rgba(129, 140, 248, 0.3);
  }

  .v2-newsletter-input {
    flex: 1;
    background: rgba(255, 255, 255, 0.02);
    border: none;
    padding: 0.625rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 300;
    color: var(--v2-text-0);
    outline: none;
    font-family: var(--v2-sans);
    min-width: 0;
  }

  .v2-newsletter-input::placeholder {
    color: var(--v2-text-3);
    font-weight: 300;
  }

  .v2-newsletter-btn {
    background: var(--v2-accent);
    color: #fff;
    border: none;
    padding: 0.625rem 1.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    font-family: var(--v2-sans);
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: opacity 0.2s;
    white-space: nowrap;
  }

  .v2-newsletter-btn:hover {
    opacity: 0.85;
  }

  .v2-newsletter-fine {
    font-size: 0.6875rem;
    font-weight: 300;
    color: var(--v2-text-3);
    opacity: 0.5;
    margin-top: 0.75rem;
  }

  /* ── Footer ────────────────────────────────────── */

  .v2-footer {
    border-top: 1px solid var(--v2-border);
    padding: 2rem 1.5rem;
  }

  .v2-footer-inner {
    max-width: var(--v2-max);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .v2-footer-brand {
    font-size: 0.6875rem;
    font-weight: 400;
    color: var(--v2-text-3);
  }

  .v2-footer-sep {
    font-size: 0.625rem;
    color: var(--v2-text-3);
    opacity: 0.25;
  }

  .v2-footer-link {
    font-size: 0.6875rem;
    font-weight: 300;
    color: var(--v2-text-3) !important;
    text-decoration: none !important;
    transition: color 0.2s;
  }

  .v2-footer-link:hover {
    color: var(--v2-text-2) !important;
  }

  /* ── Mobile ────────────────────────────────────── */

  @media (max-width: 639px) {
    .v2-featured {
      padding-top: 3rem;
      padding-bottom: 2.5rem;
    }

    .v2-nav-links {
      gap: 1.25rem;
    }

    .v2-section {
      padding: 2rem 1.5rem;
    }

    .v2-curta {
      padding-left: 0.75rem;
    }
  }
</style>
