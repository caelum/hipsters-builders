---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { mockEpisodes, mockCurtas } from '../../data/mock';

const rawEpisodes = await getCollection('episodes');
const rawCurtas = await getCollection('curtas');

const episodes = (rawEpisodes.length > 0 ? rawEpisodes : mockEpisodes)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const curtas = (rawCurtas.length > 0 ? rawCurtas : mockCurtas)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const featured = episodes[0];
const recentEpisodes = episodes.slice(1, 13);
const recentCurtas = curtas.slice(0, 6);

function formatDate(date: Date): string {
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' });
}

function podcastShort(podcast: string): string {
  const map: Record<string, string> = {
    'Hipsters Ponto Tech': 'Hipsters',
    'IA Sob Controle': 'IA Sob Controle',
    'Like a Boss': 'Like a Boss',
    'Mesa de Produto': 'Mesa de Produto',
    'Carreira Sem Fronteiras': 'Carreira SF',
  };
  return map[podcast] || podcast;
}
---

<BaseLayout title="v2">
  <Fragment slot="nav">
    <nav class="v2-nav">
      <div class="v2-nav-inner">
        <a href="/design/v2" class="v2-wordmark">Hipsters<span class="v2-wordmark-dim">.builders</span></a>
        <div class="v2-nav-links">
          <a href="#episodes">Episodios</a>
          <a href="#curtas">Curtas</a>
          <a href="#newsletter">Newsletter</a>
        </div>
      </div>
    </nav>
  </Fragment>

  <!-- Featured -->
  <section class="v2-featured">
    <p class="v2-label">Mais recente</p>
    <a href={`/episodios/${featured.id}`} class="v2-featured-link">
      <h1 class="v2-featured-title">{featured.data.title}</h1>
    </a>
    <p class="v2-featured-meta">
      <span class="v2-featured-podcast">{podcastShort(featured.data.podcast)}{featured.data.episodeNumber ? ` #${featured.data.episodeNumber}` : ''}</span>
      <span class="v2-sep">/</span>
      <span>{formatDate(featured.data.pubDate)}</span>
      {featured.data.duration && (
        <>
          <span class="v2-sep">/</span>
          <span>{featured.data.duration}</span>
        </>
      )}
    </p>
    <p class="v2-featured-desc">{featured.data.description}</p>
    {featured.data.quotes.length > 0 && (
      <blockquote class="v2-featured-quote">
        "{featured.data.quotes[0].text}"
        <cite>-- {featured.data.quotes[0].speaker}</cite>
      </blockquote>
    )}
  </section>

  <hr class="v2-divider" />

  <!-- Episodes -->
  <section id="episodes" class="v2-section">
    <div class="v2-section-header">
      <h2 class="v2-section-title">Episodios</h2>
      <span class="v2-section-count">{episodes.length}</span>
    </div>

    <div class="v2-table" role="list">
      <div class="v2-table-head" aria-hidden="true">
        <span class="v2-col-date">Data</span>
        <span class="v2-col-podcast">Podcast</span>
        <span class="v2-col-title">Titulo</span>
        <span class="v2-col-tags">Tags</span>
      </div>
      {recentEpisodes.map((ep) => (
        <a href={`/episodios/${ep.id}`} class="v2-row" role="listitem">
          <span class="v2-col-date">{formatDate(ep.data.pubDate)}</span>
          <span class="v2-col-podcast">
            <span class="v2-pill">{podcastShort(ep.data.podcast)}</span>
          </span>
          <span class="v2-col-title">
            {ep.data.title}
            {ep.data.episodeNumber ? <span class="v2-ep-num">#{ep.data.episodeNumber}</span> : null}
          </span>
          <span class="v2-col-tags">
            {ep.data.tags.slice(0, 2).map(tag => (
              <span class="v2-tag">{tag}</span>
            ))}
          </span>
        </a>
      ))}
    </div>

    <div class="v2-more">
      <a href="/episodios">Ver todos os {episodes.length} episodios</a>
    </div>
  </section>

  <hr class="v2-divider" />

  <!-- Curtas -->
  <section id="curtas" class="v2-section">
    <div class="v2-section-header">
      <h2 class="v2-section-title">Curtas</h2>
      <span class="v2-section-count">{curtas.length}</span>
    </div>

    <div class="v2-curtas-grid">
      {recentCurtas.map((c) => (
        <a href={c.data.sourceUrl || '#'} class="v2-curta" target={c.data.sourceUrl ? '_blank' : undefined} rel={c.data.sourceUrl ? 'noopener' : undefined}>
          <blockquote class="v2-curta-text">"{c.data.quote}"</blockquote>
          <div class="v2-curta-footer">
            <span class="v2-curta-speaker">{c.data.speaker}</span>
            <span class="v2-curta-context">{c.data.context}</span>
          </div>
        </a>
      ))}
    </div>

    <div class="v2-more">
      <a href="/curtas">Ver todas as {curtas.length} curtas</a>
    </div>
  </section>

  <hr class="v2-divider" />

  <!-- Newsletter -->
  <section id="newsletter" class="v2-section v2-newsletter">
    <div class="v2-newsletter-inner">
      <h2 class="v2-section-title">Newsletter semanal</h2>
      <p class="v2-newsletter-desc">Resumo curado toda quarta-feira. Sem spam.</p>
      <form class="v2-newsletter-form" action="/api/subscribe" method="POST">
        <input
          type="email"
          name="email"
          required
          placeholder="seu@email.com"
          class="v2-newsletter-input"
          autocomplete="email"
        />
        <button type="submit" class="v2-newsletter-btn">Assinar</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Base ──────────────────────────────────────────── */

  :root {
    --v2-bg: #09090b;
    --v2-surface: #111113;
    --v2-border: rgba(255, 255, 255, 0.06);
    --v2-text-1: #f0f0f5;
    --v2-text-2: #a0a0b0;
    --v2-text-3: #5a5a6e;
    --v2-accent: #6366f1;
    --v2-accent-dim: rgba(99, 102, 241, 0.15);
    --v2-mono: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
    --v2-max: 960px;
  }

  /* ── Nav ───────────────────────────────────────────── */

  .v2-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: rgba(9, 9, 11, 0.85);
    border-bottom: 1px solid var(--v2-border);
  }

  .v2-nav-inner {
    max-width: var(--v2-max);
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 3.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .v2-wordmark {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--v2-text-1) !important;
    text-decoration: none;
  }

  .v2-wordmark:hover {
    color: var(--v2-text-1) !important;
    opacity: 0.8;
  }

  .v2-wordmark-dim {
    color: var(--v2-text-3);
  }

  .v2-nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .v2-nav-links a {
    font-size: 0.8125rem;
    color: var(--v2-text-3) !important;
    text-decoration: none;
    transition: color 0.15s;
  }

  .v2-nav-links a:hover {
    color: var(--v2-text-2) !important;
  }

  /* ── Layout ────────────────────────────────────────── */

  .v2-section {
    max-width: var(--v2-max);
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
  }

  .v2-divider {
    max-width: var(--v2-max);
    margin: 0 auto;
    border: none;
    border-top: 1px solid var(--v2-border);
  }

  .v2-section-header {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    margin-bottom: 1.5rem;
  }

  .v2-section-title {
    font-size: 0.8125rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--v2-text-3);
  }

  .v2-section-count {
    font-size: 0.75rem;
    font-family: var(--v2-mono);
    color: var(--v2-text-3);
    opacity: 0.6;
  }

  /* ── Featured ──────────────────────────────────────── */

  .v2-featured {
    max-width: var(--v2-max);
    margin: 0 auto;
    padding: 4rem 1.5rem 2.5rem;
  }

  .v2-label {
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--v2-accent);
    margin-bottom: 1rem;
  }

  .v2-featured-link {
    text-decoration: none !important;
    display: block;
  }

  .v2-featured-title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 650;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--v2-text-1);
    margin-bottom: 0.875rem;
    transition: opacity 0.15s;
  }

  .v2-featured-link:hover .v2-featured-title {
    opacity: 0.75;
  }

  .v2-featured-meta {
    font-size: 0.8125rem;
    color: var(--v2-text-3);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .v2-featured-podcast {
    color: var(--v2-text-2);
    font-weight: 500;
  }

  .v2-sep {
    opacity: 0.3;
  }

  .v2-featured-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--v2-text-2);
    max-width: 640px;
  }

  .v2-featured-quote {
    margin-top: 1.5rem;
    padding-left: 1rem;
    border-left: 2px solid var(--v2-accent-dim);
    font-size: 0.875rem;
    font-style: italic;
    line-height: 1.6;
    color: var(--v2-text-2);
    max-width: 600px;
  }

  .v2-featured-quote cite {
    display: block;
    font-style: normal;
    font-size: 0.75rem;
    color: var(--v2-text-3);
    margin-top: 0.375rem;
  }

  /* ── Episode Table ─────────────────────────────────── */

  .v2-table {
    display: flex;
    flex-direction: column;
  }

  .v2-table-head {
    display: none;
  }

  @media (min-width: 768px) {
    .v2-table-head {
      display: grid;
      grid-template-columns: 5rem 9rem 1fr 12rem;
      gap: 1rem;
      padding: 0 0.75rem 0.625rem;
      font-size: 0.6875rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--v2-text-3);
      opacity: 0.6;
      border-bottom: 1px solid var(--v2-border);
    }
  }

  .v2-row {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem;
    text-decoration: none !important;
    border-bottom: 1px solid var(--v2-border);
    transition: background-color 0.12s;
  }

  .v2-row:hover {
    background-color: rgba(255, 255, 255, 0.02);
  }

  @media (min-width: 768px) {
    .v2-row {
      display: grid;
      grid-template-columns: 5rem 9rem 1fr 12rem;
      gap: 1rem;
      align-items: center;
      flex-direction: row;
    }
  }

  .v2-col-date {
    font-size: 0.8125rem;
    font-family: var(--v2-mono);
    color: var(--v2-text-3);
    white-space: nowrap;
  }

  .v2-col-podcast {
    font-size: 0.8125rem;
  }

  .v2-pill {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--v2-accent);
    background: var(--v2-accent-dim);
    border-radius: 2px;
    white-space: nowrap;
  }

  .v2-col-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--v2-text-1);
    line-height: 1.4;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 767px) {
    .v2-col-title {
      white-space: normal;
    }

    .v2-col-tags {
      margin-top: 0.125rem;
    }
  }

  .v2-ep-num {
    font-family: var(--v2-mono);
    font-size: 0.75rem;
    color: var(--v2-text-3);
    margin-left: 0.375rem;
    font-weight: 400;
  }

  .v2-col-tags {
    display: flex;
    gap: 0.375rem;
    overflow: hidden;
  }

  .v2-tag {
    font-size: 0.6875rem;
    color: var(--v2-text-3);
    background: rgba(255, 255, 255, 0.04);
    padding: 0.0625rem 0.375rem;
    border-radius: 2px;
    white-space: nowrap;
  }

  .v2-more {
    margin-top: 1.25rem;
  }

  .v2-more a {
    font-size: 0.8125rem;
    color: var(--v2-text-3) !important;
    text-decoration: none;
    transition: color 0.15s;
  }

  .v2-more a:hover {
    color: var(--v2-text-2) !important;
  }

  .v2-more a::after {
    content: ' \2192';
    opacity: 0.5;
  }

  /* ── Curtas ────────────────────────────────────────── */

  .v2-curtas-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--v2-border);
  }

  @media (min-width: 640px) {
    .v2-curtas-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .v2-curtas-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .v2-curta {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.25rem;
    background: var(--v2-bg);
    text-decoration: none !important;
    transition: background-color 0.12s;
    min-height: 8rem;
  }

  .v2-curta:hover {
    background-color: rgba(255, 255, 255, 0.015);
  }

  .v2-curta-text {
    font-size: 0.8125rem;
    font-family: var(--v2-mono);
    line-height: 1.6;
    color: var(--v2-text-2);
    margin: 0;
    /* no truncation */
  }

  .v2-curta-footer {
    margin-top: 0.75rem;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .v2-curta-speaker {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--v2-text-1);
  }

  .v2-curta-context {
    font-size: 0.6875rem;
    color: var(--v2-text-3);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 16rem;
  }

  /* ── Newsletter ────────────────────────────────────── */

  .v2-newsletter {
    padding-top: 3rem;
    padding-bottom: 4rem;
  }

  .v2-newsletter-inner {
    max-width: 28rem;
  }

  .v2-newsletter-desc {
    font-size: 0.8125rem;
    color: var(--v2-text-3);
    margin-top: 0.375rem;
    margin-bottom: 1.25rem;
  }

  .v2-newsletter-form {
    display: flex;
    gap: 0;
    border: 1px solid var(--v2-border);
    border-radius: 4px;
    overflow: hidden;
    transition: border-color 0.15s;
  }

  .v2-newsletter-form:focus-within {
    border-color: rgba(99, 102, 241, 0.4);
  }

  .v2-newsletter-input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 0.625rem 0.875rem;
    font-size: 0.8125rem;
    color: var(--v2-text-1);
    outline: none;
    font-family: inherit;
    min-width: 0;
  }

  .v2-newsletter-input::placeholder {
    color: var(--v2-text-3);
  }

  .v2-newsletter-btn {
    background: var(--v2-accent);
    color: #fff;
    border: none;
    padding: 0.625rem 1.25rem;
    font-size: 0.8125rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: opacity 0.15s;
    white-space: nowrap;
  }

  .v2-newsletter-btn:hover {
    opacity: 0.85;
  }

  /* ── Mobile refinements ────────────────────────────── */

  @media (max-width: 639px) {
    .v2-featured {
      padding-top: 2.5rem;
    }

    .v2-nav-links {
      gap: 1rem;
    }

    .v2-col-date {
      font-size: 0.75rem;
    }

    .v2-col-podcast {
      order: -1;
    }
  }
</style>
