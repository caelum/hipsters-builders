---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { mockEpisodes, mockCurtas } from '../../data/mock';
import { renderInlineMd } from '../../utils/render-inline-md';
import NewsletterForm from '../../components/NewsletterForm.astro';

const rawEpisodes = await getCollection('episodes');
const rawCurtas = await getCollection('curtas');

const episodes = (rawEpisodes.length > 0 ? rawEpisodes : mockEpisodes)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const curtas = (rawCurtas.length > 0 ? rawCurtas : mockCurtas)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const heroEpisode = episodes[0];
const recentEpisodes = episodes.slice(1, 9);
const featuredCurtas = curtas.slice(0, 6);

function formatDate(date: Date): string {
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
}

function formatDateShort(date: Date): string {
  return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' });
}

function podcastLabel(podcast: string): string {
  if (podcast === 'Hipsters Ponto Tech') return 'Hipsters';
  if (podcast === 'IA Sob Controle') return 'IA Sob Controle';
  return podcast;
}

function podcastAccentClass(podcast: string): string {
  if (podcast === 'Hipsters Ponto Tech') return 'ed-label--hipsters';
  if (podcast === 'IA Sob Controle') return 'ed-label--ia';
  if (podcast === 'Like a Boss') return 'ed-label--boss';
  if (podcast === 'Mesa de Produto') return 'ed-label--mesa';
  return 'ed-label--default';
}

function stripMd(text: string): string {
  return text
    .replace(/!\[[^\]]*\]\([^)]+\)/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/\*\*(.+?)\*\*/g, '$1')
    .replace(/\*(.+?)\*/g, '$1')
    .replace(/\n+/g, ' ')
    .trim();
}

function weight(quote: string): 'featured' | 'standard' | 'compact' {
  const len = stripMd(quote).length;
  if (len > 280) return 'featured';
  if (len < 120) return 'compact';
  return 'standard';
}
---

<BaseLayout title="Editorial">
  <Fragment slot="nav">
    <!-- Editorial nav replaces the dark one -->
  </Fragment>
  <Fragment slot="footer">
    <!-- V1 has its own footer inside ed-page -->
  </Fragment>

  <div class="ed-page">
    <!-- HEADER -->
    <header class="ed-header">
      <div class="ed-header__inner">
        <div class="ed-header__brand">
          <a href="/design/v1" class="ed-header__logo">
            <span class="ed-header__logo-h">Hipsters</span><span class="ed-header__logo-dot">.</span><span class="ed-header__logo-b">builders</span>
          </a>
          <p class="ed-header__tagline">Os melhores momentos da Hipsters Network</p>
        </div>
        <nav class="ed-header__nav">
          <a href="/episodios" class="ed-header__nav-link">Episodios</a>
          <a href="/curtas" class="ed-header__nav-link">Curtas</a>
          <a href="/newsletter" class="ed-header__nav-link">Newsletter</a>
        </nav>
      </div>
      <div class="ed-header__rule"></div>
    </header>

    <!-- HERO — Latest episode -->
    <section class="ed-section">
      <div class="ed-section__label">Destaque da Semana</div>
      <article class="ed-hero">
        <div class="ed-hero__meta">
          <span class={`ed-label ${podcastAccentClass(heroEpisode.data.podcast)}`}>
            {podcastLabel(heroEpisode.data.podcast)}{heroEpisode.data.episodeNumber ? ` #${heroEpisode.data.episodeNumber}` : ''}
          </span>
          <time class="ed-meta-date" datetime={heroEpisode.data.pubDate.toISOString()}>
            {formatDate(heroEpisode.data.pubDate)}
          </time>
        </div>
        <h1 class="ed-hero__title">
          <a href={`/episodios/${heroEpisode.id}`}>{heroEpisode.data.title}</a>
        </h1>
        <p class="ed-hero__description">{heroEpisode.data.description}</p>
        <div class="ed-hero__authors">
          {heroEpisode.data.authors.join(', ')}
        </div>

        {heroEpisode.data.quotes.length > 0 && (
          <aside class="ed-hero__quote">
            <div class="ed-hero__quote-bar" aria-hidden="true" />
            <blockquote>
              <p>{heroEpisode.data.quotes[0].text}</p>
              <footer>
                <cite>{heroEpisode.data.quotes[0].speaker}</cite>
                {heroEpisode.data.quotes[0].timestamp && (
                  <span class="ed-hero__quote-time">{heroEpisode.data.quotes[0].timestamp}</span>
                )}
              </footer>
            </blockquote>
          </aside>
        )}
      </article>
    </section>

    <!-- RECENT EPISODES -->
    {recentEpisodes.length > 0 && (
      <section class="ed-section">
        <div class="ed-section__label">Episodios Recentes</div>
        <ol class="ed-episodes">
          {recentEpisodes.map((ep) => (
            <li class="ed-ep">
              <a href={`/episodios/${ep.id}`} class="ed-ep__link">
                <div class="ed-ep__left">
                  <span class={`ed-label ed-label--sm ${podcastAccentClass(ep.data.podcast)}`}>
                    {podcastLabel(ep.data.podcast)}
                  </span>
                  <h3 class="ed-ep__title">{ep.data.title}</h3>
                </div>
                <time class="ed-ep__date" datetime={ep.data.pubDate.toISOString()}>
                  {formatDateShort(ep.data.pubDate)}
                </time>
              </a>
            </li>
          ))}
        </ol>
        <div class="ed-section__more">
          <a href="/episodios">Todos os {episodes.length} episodios &rarr;</a>
        </div>
      </section>
    )}

    <!-- CURTAS — Masonry quote wall -->
    {featuredCurtas.length > 0 && (
      <section class="ed-section">
        <div class="ed-section__label">Curtas</div>
        <p class="ed-section__subtitle">Frases que marcaram as conversas recentes</p>
        <div class="ed-masonry">
          {featuredCurtas.map((c, i) => {
            const w = i === 0 ? 'featured' : weight(c.data.quote);
            return (
              <article class={`ed-quote ed-quote--${w}`}>
                {w === 'featured' && <div class="ed-quote__accent" aria-hidden="true" />}
                <blockquote class="ed-quote__body">
                  <p set:html={renderInlineMd(c.data.quote)} />
                </blockquote>
                <footer class="ed-quote__foot">
                  <span class="ed-quote__speaker">{c.data.speaker}</span>
                  <span class="ed-quote__source">{c.data.context}</span>
                </footer>
              </article>
            );
          })}
        </div>
        <div class="ed-section__more">
          <a href="/curtas">Todas as {curtas.length} curtas &rarr;</a>
        </div>
      </section>
    )}

    <!-- NEWSLETTER -->
    <section class="ed-newsletter">
      <h2 class="ed-newsletter__title">Newsletter semanal</h2>
      <p class="ed-newsletter__desc">
        Toda quarta-feira, um resumo curado dos melhores episodios e discussoes da comunidade. Direto no seu e-mail, sem ruido.
      </p>
      <div class="ed-newsletter__form">
        <NewsletterForm variant="block" />
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="ed-footer">
      <div class="ed-footer__inner">
        <p>Hipsters Builders &mdash; parte da <a href="https://hipsters.tech">Hipsters Network</a> &middot; <a href="https://alura.com.br">Alura</a></p>
      </div>
    </footer>
  </div>
</BaseLayout>

<style>
  /* =========================================
     EDITORIAL DESIGN — v1
     Hipsters.builders newspaper-style layout
     ========================================= */

  /* --- Fonts --- */
  @import url('https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&family=Inter:wght@400;500;600&display=swap');

  /* --- Override dark theme from global.css --- */
  :global(html),
  :global(body) {
    background: #faf9f7 !important;
    color: #1a1a1a !important;
  }

  :global(body > main) {
    max-width: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  :global(a) {
    color: inherit;
    text-decoration: none;
  }

  :global(::selection) {
    background: rgba(196, 52, 45, 0.2);
  }

  .ed-page {
    --ed-bg: #faf9f7;
    --ed-bg-warm: #f5f3ef;
    --ed-ink: #1a1a1a;
    --ed-ink-secondary: #4a4a4a;
    --ed-ink-muted: #8a8a8a;
    --ed-ink-faint: #b5b5b5;
    --ed-rule: #d4d0c8;
    --ed-rule-strong: #1a1a1a;
    --ed-accent: #c4342d;
    --ed-accent-hover: #a02a24;
    --ed-serif: 'Source Serif 4', Georgia, 'Times New Roman', serif;
    --ed-sans: 'Inter', system-ui, -apple-system, sans-serif;

    background: var(--ed-bg);
    color: var(--ed-ink);
    font-family: var(--ed-sans);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  .ed-page a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s;
  }

  .ed-page a:hover {
    color: var(--ed-accent);
  }

  /* --- HEADER --- */
  .ed-header {
    padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 4vw, 2rem) 0;
    max-width: 72rem;
    margin: 0 auto;
  }

  .ed-header__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding-bottom: clamp(1.25rem, 3vw, 2rem);
  }

  @media (min-width: 640px) {
    .ed-header__inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: baseline;
    }
  }

  .ed-header__brand {
    text-align: center;
  }

  @media (min-width: 640px) {
    .ed-header__brand {
      text-align: left;
    }
  }

  .ed-header__logo {
    display: inline-block;
    font-family: var(--ed-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--ed-ink);
  }

  .ed-header__logo:hover {
    color: var(--ed-ink);
  }

  .ed-header__logo-h {
    color: var(--ed-ink);
  }

  .ed-header__logo-dot {
    color: var(--ed-accent);
  }

  .ed-header__logo-b {
    color: var(--ed-ink-secondary);
    font-weight: 400;
  }

  .ed-header__tagline {
    font-size: clamp(0.75rem, 1.5vw, 0.875rem);
    color: var(--ed-ink-muted);
    margin-top: 0.25rem;
    letter-spacing: 0.03em;
    font-style: italic;
    font-family: var(--ed-serif);
  }

  .ed-header__nav {
    display: flex;
    gap: clamp(1rem, 2.5vw, 2rem);
  }

  .ed-header__nav-link {
    font-size: clamp(0.6875rem, 1.2vw, 0.8125rem);
    font-weight: 500;
    color: var(--ed-ink-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: color 0.15s;
    padding: 0.25rem 0;
    border-bottom: 2px solid transparent;
  }

  .ed-header__nav-link:hover {
    color: var(--ed-ink);
    border-bottom-color: var(--ed-rule);
  }

  .ed-header__rule {
    height: 3px;
    background: var(--ed-rule-strong);
    margin-top: 0;
  }

  .ed-header__rule::after {
    content: '';
    display: block;
    height: 1px;
    background: var(--ed-rule);
    margin-top: 3px;
  }

  /* --- SECTIONS --- */
  .ed-section {
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1rem, 4vw, 2rem);
    border-bottom: 1px solid var(--ed-rule);
  }

  .ed-section:last-of-type {
    border-bottom: none;
  }

  .ed-section__label {
    font-family: var(--ed-sans);
    font-size: clamp(0.625rem, 1vw, 0.6875rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ed-accent);
    margin-bottom: clamp(1rem, 2.5vw, 1.5rem);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--ed-rule);
  }

  .ed-section__subtitle {
    font-family: var(--ed-serif);
    font-size: clamp(1rem, 1.8vw, 1.0625rem);
    color: var(--ed-ink-secondary);
    margin-top: -0.75rem;
    margin-bottom: 1.75rem;
    font-style: italic;
  }

  .ed-section__more {
    margin-top: 1.5rem;
    padding-top: 1rem;
  }

  .ed-section__more a {
    font-family: var(--ed-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--ed-accent);
    letter-spacing: 0.01em;
  }

  .ed-section__more a:hover {
    color: var(--ed-accent-hover);
  }

  /* --- LABELS (podcast badges) --- */
  .ed-label {
    display: inline-block;
    font-family: var(--ed-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.1875rem 0.5rem;
    border-radius: 2px;
  }

  .ed-label--sm {
    font-size: 0.625rem;
    padding: 0.125rem 0.375rem;
  }

  .ed-label--hipsters {
    background: #ede9fe;
    color: #5b21b6;
  }

  .ed-label--ia {
    background: #fce7f3;
    color: #9d174d;
  }

  .ed-label--boss {
    background: #fef3c7;
    color: #92400e;
  }

  .ed-label--mesa {
    background: #d1fae5;
    color: #065f46;
  }

  .ed-label--default {
    background: #f3f4f6;
    color: #374151;
  }

  /* --- META DATE --- */
  .ed-meta-date {
    font-size: 0.75rem;
    color: var(--ed-ink-muted);
    font-variant-numeric: tabular-nums;
  }

  /* =========================================
     HERO
     ========================================= */
  .ed-hero {
    padding: 0.5rem 0 0;
  }

  .ed-hero__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .ed-hero__title {
    font-family: var(--ed-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ed-ink);
    margin-bottom: 1rem;
  }

  .ed-hero__title a {
    color: inherit;
    transition: color 0.15s;
  }

  .ed-hero__title a:hover {
    color: var(--ed-accent);
  }

  .ed-hero__description {
    font-family: var(--ed-serif);
    font-size: clamp(1.0625rem, 2vw, 1.1875rem);
    line-height: 1.7;
    color: var(--ed-ink-secondary);
    max-width: 42rem;
    margin-bottom: 0.75rem;
  }

  .ed-hero__authors {
    font-family: var(--ed-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--ed-ink-muted);
  }

  /* Hero featured quote — accent bar + oversized quotation marks */
  .ed-hero__quote {
    margin-top: 2rem;
    padding-left: 1.25rem;
    position: relative;
    max-width: 36rem;
  }

  .ed-hero__quote-bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--ed-accent);
  }

  .ed-hero__quote blockquote {
    margin: 0;
  }

  .ed-hero__quote blockquote p {
    font-family: var(--ed-serif);
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    font-style: italic;
    line-height: 1.65;
    color: var(--ed-ink);
  }

  .ed-hero__quote blockquote p::before {
    content: '\201c';
    font-family: var(--ed-serif);
    font-size: 3em;
    line-height: 0;
    vertical-align: -0.35em;
    color: var(--ed-accent);
    opacity: 0.35;
    margin-right: 0.05em;
    font-weight: 700;
  }

  .ed-hero__quote footer {
    margin-top: 0.625rem;
    font-family: var(--ed-sans);
    font-size: 0.8125rem;
  }

  .ed-hero__quote cite {
    font-style: normal;
    font-weight: 600;
    color: var(--ed-ink);
  }

  .ed-hero__quote-time {
    color: var(--ed-ink-faint);
    margin-left: 0.5rem;
  }

  /* =========================================
     EPISODE LIST — clean rows, date column
     ========================================= */
  .ed-episodes {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ed-ep {
    border-bottom: 1px solid var(--ed-rule);
  }

  .ed-ep:last-child {
    border-bottom: none;
  }

  .ed-ep__link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.875rem 0;
    color: inherit;
    text-decoration: none;
    transition: none;
  }

  .ed-ep__link:hover {
    color: inherit;
  }

  .ed-ep__link:hover .ed-ep__title {
    color: var(--ed-accent);
  }

  .ed-ep__left {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    min-width: 0;
  }

  .ed-ep__title {
    font-family: var(--ed-serif);
    font-size: clamp(0.9375rem, 1.5vw, 1.0625rem);
    font-weight: 600;
    line-height: 1.35;
    color: var(--ed-ink);
    transition: color 0.12s;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (min-width: 640px) {
    .ed-ep__title {
      white-space: normal;
    }
  }

  .ed-ep__date {
    font-family: var(--ed-sans);
    font-size: 0.75rem;
    color: var(--ed-ink-muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* =========================================
     CURTAS — CSS columns masonry
     ========================================= */
  .ed-masonry {
    column-count: 1;
    column-gap: 2rem;
  }

  @media (min-width: 640px) {
    .ed-masonry {
      column-count: 2;
    }
  }

  @media (min-width: 1024px) {
    .ed-masonry {
      column-count: 3;
    }
  }

  .ed-quote {
    break-inside: avoid;
    margin-bottom: 1.75rem;
    position: relative;
  }

  .ed-quote--featured {
    padding-left: 1.25rem;
    margin-bottom: 2rem;
  }

  .ed-quote__accent {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--ed-accent);
  }

  .ed-quote__body {
    margin: 0;
  }

  .ed-quote__body p {
    font-family: var(--ed-serif);
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--ed-ink);
  }

  .ed-quote--featured .ed-quote__body p {
    font-size: clamp(1rem, 2vw, 1.125rem);
    line-height: 1.7;
  }

  .ed-quote--compact .ed-quote__body p {
    font-size: 0.875rem;
  }

  /* Oversized opening quote mark */
  .ed-quote__body p::before {
    content: '\201c';
    font-family: var(--ed-serif);
    font-size: 2.5em;
    line-height: 0;
    vertical-align: -0.35em;
    color: var(--ed-accent);
    opacity: 0.25;
    margin-right: 0.05em;
    font-weight: 700;
  }

  .ed-quote--featured .ed-quote__body p::before {
    font-size: 3em;
    opacity: 0.35;
  }

  /* Inline markdown in quotes */
  .ed-quote__body :global(strong) {
    font-weight: 600;
    color: var(--ed-ink);
  }

  .ed-quote__body :global(em) {
    font-style: italic;
  }

  .ed-quote__body :global(a) {
    color: var(--ed-accent);
    text-decoration: underline;
    text-decoration-color: var(--ed-rule);
    text-underline-offset: 2px;
    word-break: break-all;
    transition: text-decoration-color 0.12s;
  }

  .ed-quote__body :global(a:hover) {
    text-decoration-color: var(--ed-accent);
  }

  .ed-quote__body :global(.quote-img) {
    display: block;
    width: 100%;
    max-height: 18rem;
    object-fit: cover;
    margin: 0.75rem 0;
    border: 1px solid var(--ed-rule);
  }

  .ed-quote__foot {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 0.75rem;
  }

  .ed-quote__speaker {
    font-family: var(--ed-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--ed-ink);
  }

  .ed-quote__source {
    font-family: var(--ed-sans);
    font-size: 0.6875rem;
    color: var(--ed-ink-faint);
    letter-spacing: 0.01em;
    line-height: 1.4;
  }

  /* =========================================
     NEWSLETTER — centered, warm background
     ========================================= */
  .ed-newsletter {
    background: var(--ed-bg-warm);
    padding: clamp(2.5rem, 5vw, 4rem) clamp(1rem, 4vw, 2rem);
    text-align: center;
  }

  .ed-newsletter__title {
    font-family: var(--ed-serif);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--ed-ink);
    margin-bottom: 0.75rem;
  }

  .ed-newsletter__desc {
    font-family: var(--ed-serif);
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--ed-ink-secondary);
    max-width: 32rem;
    margin: 0 auto 1.5rem;
  }

  .ed-newsletter__form {
    max-width: 28rem;
    margin: 0 auto;
  }

  /* Center the fine print from NewsletterForm */
  .ed-newsletter__form :global(.nl-form-wrap) {
    text-align: center;
  }

  .ed-newsletter__form :global(.nl-form__fine) {
    text-align: center;
  }

  /* =========================================
     FOOTER — refined with decorative dash
     ========================================= */
  .ed-footer {
    max-width: 72rem;
