---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { mockEpisodes, mockCurtas } from '../../data/mock';

const rawEpisodes = await getCollection('episodes');
const rawCurtas = await getCollection('curtas');

const episodes = (rawEpisodes.length > 0 ? rawEpisodes : mockEpisodes)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const curtas = (rawCurtas.length > 0 ? rawCurtas : mockCurtas)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

// Featured: latest episode with quotes
const featured = episodes.find(ep => ep.data.quotes.length > 0) || episodes[0];

// Split by podcast
const hipsters = episodes.filter(ep => ep.data.podcast === 'Hipsters Ponto Tech').slice(0, 8);
const iaSobControle = episodes.filter(ep => ep.data.podcast === 'IA Sob Controle').slice(0, 8);

// Best curtas: pick ones with shorter, punchier quotes
const bestCurtas = curtas.slice(0, 6);

function formatDate(date: Date): string {
  return new Date(date).toLocaleDateString('pt-BR', { day: 'numeric', month: 'short', year: 'numeric' });
}

function truncate(text: string, maxLen: number): string {
  if (text.length <= maxLen) return text;
  return text.slice(0, maxLen).replace(/\s+\S*$/, '') + '...';
}

function podcastInitials(name: string): string {
  return name.split(' ').map(w => w[0]).filter(c => c === c.toUpperCase()).join('').slice(0, 3);
}
---

<BaseLayout title="Magazine" description="Hipsters Builders -- os melhores momentos dos podcasts da Hipsters Network">
  <Fragment slot="nav"><!-- no nav on this design --></Fragment>

  <div class="v3-page">
    <!-- Header -->
    <header class="mg-header">
      <a href="/" class="mg-brand">
        <span class="mg-brand-h">Hipsters</span><span class="mg-brand-dot">.</span><span class="mg-brand-b">builders</span>
      </a>
      <nav class="mg-nav">
        <a href="/episodios">Episodios</a>
        <a href="/curtas">Curtas</a>
        <a href="/newsletter">Newsletter</a>
      </nav>
    </header>

    <!-- Hero: Magazine Cover -->
    <section class="mg-hero">
      <div class="mg-hero-bg"></div>
      <div class="mg-hero-gradient"></div>

      <div class="mg-hero-content">
        <span class="mg-hero-overline">
          {featured.data.podcast}
          {featured.data.episodeNumber && ` #${featured.data.episodeNumber}`}
        </span>

        <h1 class="mg-hero-title">{featured.data.title}</h1>

        <p class="mg-hero-desc">{truncate(featured.data.description, 220)}</p>

        <div class="mg-hero-actions">
          <a href={`/episodios/${featured.id}`} class="mg-btn mg-btn--gold">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
            Ouvir episodio
          </a>
          <a href="/episodios" class="mg-btn mg-btn--ghost">
            Ver todos
          </a>
        </div>

        <div class="mg-hero-meta-row">
          <span>{formatDate(featured.data.pubDate)}</span>
          {featured.data.authors.length > 0 && (
            <span>{featured.data.authors.slice(0, 3).join(', ')}</span>
          )}
          {featured.data.segmentCount && (
            <span>{featured.data.segmentCount} segmentos</span>
          )}
        </div>
      </div>

      {featured.data.quotes.length > 0 && (
        <aside class="mg-hero-aside">
          <div class="mg-hero-pullquote">
            <blockquote>
              <p>{truncate(featured.data.quotes[0].text, 200)}</p>
            </blockquote>
            <cite>{featured.data.quotes[0].speaker}</cite>
          </div>
        </aside>
      )}
    </section>

    <!-- Hipsters Ponto Tech -->
    {hipsters.length > 0 && (
      <section class="mg-section">
        <div class="mg-section-inner">
          <div class="mg-section-header">
            <div class="mg-section-title-group">
              <span class="mg-section-overline">Podcast</span>
              <h2 class="mg-section-title">Hipsters Ponto Tech</h2>
            </div>
            <a href="/episodios" class="mg-section-link">Ver todos &rarr;</a>
          </div>
          <div class="mg-featured-grid">
            {hipsters.map(ep => (
              <a href={`/episodios/${ep.id}`} class="mg-ep-card">
                <div class={`mg-ep-card-cover mg-ep-card-cover--hipsters`}>
                  {ep.data.episodeNumber && (
                    <span class="mg-ep-card-number">#{ep.data.episodeNumber}</span>
                  )}
                  <div class="mg-ep-card-play">
                    <svg viewBox="0 0 24 24"><polygon points="5,3 19,12 5,21"/></svg>
                  </div>
                </div>
                <div class="mg-ep-card-body">
                  <span class="mg-ep-card-label mg-ep-card-label--hipsters">Hipsters Ponto Tech</span>
                  <h3 class="mg-ep-card-title">{truncate(ep.data.title, 70)}</h3>
                  {ep.data.quotes.length > 0 && (
                    <p class="mg-ep-card-quote">"{truncate(ep.data.quotes[0].text, 120)}"</p>
                  )}
                  <div class="mg-ep-card-footer">
                    <span>{formatDate(ep.data.pubDate)}</span>
                    {ep.data.authors.length > 0 && (
                      <span>{ep.data.authors[0]}</span>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <hr class="mg-divider" />

    <!-- IA Sob Controle -->
    {iaSobControle.length > 0 && (
      <section class="mg-section">
        <div class="mg-section-inner">
          <div class="mg-section-header">
            <div class="mg-section-title-group">
              <span class="mg-section-overline">Podcast</span>
              <h2 class="mg-section-title">IA Sob Controle</h2>
            </div>
            <a href="/episodios" class="mg-section-link">Ver todos &rarr;</a>
          </div>
          <div class="mg-carousel-wrap">
            <div class="mg-carousel">
              {iaSobControle.map(ep => (
                <a href={`/episodios/${ep.id}`} class="mg-ep-card">
                  <div class={`mg-ep-card-cover mg-ep-card-cover--ia`}>
                    {ep.data.episodeNumber && (
                      <span class="mg-ep-card-number">#{ep.data.episodeNumber}</span>
                    )}
                    <div class="mg-ep-card-play">
                      <svg viewBox="0 0 24 24"><polygon points="5,3 19,12 5,21"/></svg>
                    </div>
                  </div>
                  <div class="mg-ep-card-body">
                    <span class="mg-ep-card-label mg-ep-card-label--ia">IA Sob Controle</span>
                    <h3 class="mg-ep-card-title">{truncate(ep.data.title, 70)}</h3>
                    {ep.data.quotes.length > 0 && (
                      <p class="mg-ep-card-quote">"{truncate(ep.data.quotes[0].text, 120)}"</p>
                    )}
                    <div class="mg-ep-card-footer">
                      <span>{formatDate(ep.data.pubDate)}</span>
                      {ep.data.authors.length > 0 && (
                        <span>{ep.data.authors[0]}</span>
                      )}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- Insights da Comunidade -->
    <section class="mg-section mg-insights">
      <div class="mg-section-inner">
        <div class="mg-section-header">
          <div class="mg-section-title-group">
            <span class="mg-section-overline">Vozes</span>
            <h2 class="mg-section-title">Insights da Comunidade</h2>
          </div>
          <a href="/curtas" class="mg-section-link">Ver todas &rarr;</a>
        </div>
        <div class="mg-quotes-masonry">
          {bestCurtas.map((c, i) => (
            <div class={`mg-pullquote ${i === 0 ? 'mg-pullquote--featured' : ''}`}>
              <p class="mg-pullquote-text">{truncate(c.data.quote, 220)}</p>
              <span class="mg-pullquote-speaker">{c.data.speaker}</span>
              <p class="mg-pullquote-context">{c.data.context}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <hr class="mg-divider" />

    <!-- Newsletter -->
    <section class="mg-section mg-newsletter">
      <div class="mg-newsletter-inner">
        <span class="mg-newsletter-overline">Newsletter</span>
        <h2 class="mg-newsletter-title">Fique por dentro</h2>
        <p class="mg-newsletter-desc">
          Receba os melhores momentos dos podcasts, quotes e discussoes da comunidade Hipsters direto no seu email. Toda quarta-feira.
        </p>
        <form class="mg-newsletter-form" action="https://buttondown.com/api/emails/embed-subscribe/hipsters-builders" method="post" target="_blank">
          <input
            type="email"
            name="email"
            required
            placeholder="seu@email.com"
            class="mg-newsletter-input"
          />
          <button type="submit" class="mg-newsletter-btn">Assinar</button>
        </form>
        <p class="mg-newsletter-fine">Sem spam. Cancelamento com 1 clique.</p>
      </div>
    </section>

    <!-- Footer -->
    <footer class="mg-footer">
      <div class="mg-footer-inner">
        <span>Hipsters Builders &copy; 2025</span>
        <div class="mg-footer-links">
          <a href="https://hipsters.tech">Hipsters Network</a>
          <a href="https://alura.com.br">Alura</a>
          <a href="/rss.xml">RSS</a>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>

<style is:global>
    /* =========================================
       V3 — MAGAZINE
       Dark warm, streaming-inspired
       Serif headlines + sans UI, cinematic feel
       ========================================= */

    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Inter:wght@400;500;600;700&display=swap');

    /* ---- Override BaseLayout for full-bleed ---- */
    :global(html),
    :global(body) {
      background: #1a1412 !important;
      color: #f5f0eb !important;
    }

    :global(body > main) {
      max-width: none !important;
      padding: 0 !important;
      margin: 0 !important;
    }

    :global(body > footer) {
      display: none !important;
    }

    :global(::selection) {
      background: rgba(245, 158, 11, 0.3);
      color: #fff;
    }

    .v3-page {
      --mg-bg: #1a1412;
      --mg-bg-warm: #1f1a16;
      --mg-bg-card: #241e19;
      --mg-bg-card-hover: #2d261f;
      --mg-bg-elevated: #302820;
      --mg-text: #f5f0eb;
      --mg-text-secondary: #c4b8a8;
      --mg-text-muted: #8a7e6e;
      --mg-text-faint: #5c5347;
      --mg-gold: #f59e0b;
      --mg-gold-light: #fbbf24;
      --mg-gold-dim: #b45309;
      --mg-gold-glow: rgba(245, 158, 11, 0.15);
      --mg-rule: rgba(196, 176, 148, 0.12);
      --mg-rule-gold: rgba(245, 158, 11, 0.2);
      --mg-hipsters-from: #6366f1;
      --mg-hipsters-to: #4f46e5;
      --mg-ia-from: #10b981;
      --mg-ia-to: #059669;
      --mg-serif: 'Playfair Display', Georgia, 'Times New Roman', serif;
      --mg-sans: 'Inter', system-ui, -apple-system, sans-serif;

      background: var(--mg-bg);
      color: var(--mg-text);
      font-family: var(--mg-sans);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    .v3-page a {
      color: inherit;
      text-decoration: none;
    }

    /* ---- Subtle texture overlay ---- */
    .v3-page::before {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 9999;
      background:
        repeating-linear-gradient(
          0deg,
          transparent,
          transparent 2px,
          rgba(0, 0, 0, 0.015) 2px,
          rgba(0, 0, 0, 0.015) 4px
        );
      mix-blend-mode: multiply;
    }

    /* =========================================
       HEADER — Floating brand
       ========================================= */
    .mg-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 1.5rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: linear-gradient(to bottom, rgba(26, 20, 18, 0.95) 0%, transparent 100%);
      pointer-events: none;
    }

    .mg-header > * {
      pointer-events: auto;
    }

    .mg-brand {
      display: flex;
      align-items: baseline;
      gap: 0;
    }

    .mg-brand-h {
      font-family: var(--mg-serif);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--mg-text);
      letter-spacing: -0.02em;
    }

    .mg-brand-dot {
      font-family: var(--mg-serif);
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--mg-gold);
    }

    .mg-brand-b {
      font-family: var(--mg-sans);
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--mg-text-secondary);
      letter-spacing: 0.04em;
    }

    .mg-nav {
      display: flex;
      gap: 2rem;
    }

    .mg-nav a {
      font-family: var(--mg-sans);
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--mg-text-secondary);
      transition: color 0.2s;
    }

    .mg-nav a:hover {
      color: var(--mg-gold);
    }

    /* =========================================
       HERO — Cinematic magazine cover
       ========================================= */
    .mg-hero {
      position: relative;
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr;
      align-items: end;
      overflow: hidden;
    }

    @media (min-width: 1024px) {
      .mg-hero {
        grid-template-columns: 1fr 1fr;
        align-items: end;
      }
    }

    /* Background: warm abstract gradient with glow spots */
    .mg-hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .mg-hero-bg::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 120% 80% at 80% 20%, rgba(245, 158, 11, 0.08) 0%, transparent 60%),
        radial-gradient(ellipse 60% 60% at 15% 80%, rgba(99, 102, 241, 0.06) 0%, transparent 50%),
        radial-gradient(ellipse 40% 40% at 60% 60%, rgba(180, 83, 9, 0.05) 0%, transparent 50%),
        linear-gradient(160deg, #1a1412 0%, #241e19 30%, #1a1412 50%, #1f1816 80%, #1a1412 100%);
    }

    /* Film-grain-like noise texture */
    .mg-hero-bg::after {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
      background-size: 256px 256px;
      opacity: 0.4;
      mix-blend-mode: overlay;
    }

    .mg-hero-gradient {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 50%;
      background: linear-gradient(to top, var(--mg-bg) 0%, transparent 100%);
      z-index: 1;
    }

    /* Left column: main content */
    .mg-hero-content {
      position: relative;
      z-index: 2;
      padding: 8rem 2rem 4rem;
      max-width: 40rem;
    }

    @media (min-width: 768px) {
      .mg-hero-content {
        padding: 10rem 3rem 5rem;
      }
    }

    @media (min-width: 1024px) {
      .mg-hero-content {
        padding: 10rem 4rem 5rem 4rem;
        max-width: none;
      }
    }

    .mg-hero-overline {
      display: inline-flex;
      align-items: center;
      gap: 0.625rem;
      font-family: var(--mg-sans);
      font-size: 0.6875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--mg-gold);
      margin-bottom: 1.75rem;
    }

    .mg-hero-overline::before {
      content: '';
      display: inline-block;
      width: 2rem;
      height: 1px;
      background: var(--mg-gold);
    }

    .mg-hero-title {
      font-family: var(--mg-serif);
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 900;
      line-height: 1.05;
      letter-spacing: -0.02em;
      color: var(--mg-text);
      margin-bottom: 1.5rem;
    }

    .mg-hero-desc {
      font-family: var(--mg-sans);
      font-size: 1.0625rem;
      line-height: 1.7;
      color: var(--mg-text-secondary);
      max-width: 32rem;
      margin-bottom: 2.5rem;
    }

    .mg-hero-actions {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      flex-wrap: wrap;
    }

    .mg-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.625rem;
      padding: 0.875rem 2rem;
      font-family: var(--mg-sans);
      font-size: 0.8125rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      border-radius: 2px;
      transition: all 0.3s ease;
      text-decoration: none;
    }

    .mg-btn--gold {
      background: var(--mg-gold);
      color: #1a1412;
    }

    .mg-btn--gold:hover {
      background: var(--mg-gold-light);
      color: #1a1412;
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(245, 158, 11, 0.25);
    }

    .mg-btn--ghost {
      background: transparent;
      color: var(--mg-text-secondary);
      border: 1px solid var(--mg-rule);
    }

    .mg-btn--ghost:hover {
      color: var(--mg-gold);
      border-color: var(--mg-gold-dim);
    }

    .mg-hero-meta-row {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      margin-top: 2.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--mg-rule);
      font-family: var(--mg-sans);
      font-size: 0.75rem;
      color: var(--mg-text-muted);
    }

    .mg-hero-meta-row span + span::before {
      content: '\00b7';
      margin-right: 1.25rem;
      color: var(--mg-text-faint);
    }

    /* Right column: featured quote (desktop only) */
    .mg-hero-aside {
      position: relative;
      z-index: 2;
      display: none;
      padding: 10rem 4rem 5rem 2rem;
    }

    @media (min-width: 1024px) {
      .mg-hero-aside {
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
      }
    }

    .mg-hero-pullquote {
      position: relative;
      padding-left: 2rem;
      max-width: 28rem;
    }

    .mg-hero-pullquote::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
      background: linear-gradient(to bottom, var(--mg-gold), var(--mg-gold-dim));
    }

    .mg-hero-pullquote blockquote {
      margin: 0;
    }

    .mg-hero-pullquote blockquote p {
      font-family: var(--mg-serif);
      font-size: clamp(1.125rem, 2vw, 1.375rem);
      font-style: italic;
      line-height: 1.6;
      color: var(--mg-text);
    }

    .mg-hero-pullquote cite {
      display: block;
      margin-top: 1rem;
      font-family: var(--mg-sans);
      font-size: 0.8125rem;
      font-style: normal;
      font-weight: 600;
      color: var(--mg-gold);
      letter-spacing: 0.02em;
    }

    .mg-hero-pullquote cite::before {
      content: '\2014\00a0';
      color: var(--mg-text-faint);
    }

    /* =========================================
       SECTIONS — Shared
       ========================================= */
    .mg-section {
      padding: 5rem 2rem;
      position: relative;
    }

    @media (min-width: 768px) {
      .mg-section {
        padding: 6rem 3rem;
      }
    }

    @media (min-width: 1024px) {
      .mg-section {
        padding: 6rem 4rem;
      }
    }

    .mg-section-inner {
      max-width: 80rem;
      margin: 0 auto;
    }

    .mg-section-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 3rem;
    }

    .mg-section-title-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .mg-section-overline {
      font-family: var(--mg-sans);
      font-size: 0.6875rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--mg-gold);
      display: flex;
      align-items: center;
      gap: 0.625rem;
    }

    .mg-section-overline::before {
      content: '';
      display: inline-block;
      width: 1.25rem;
      height: 1px;
      background: var(--mg-gold-dim);
    }

    .mg-section-title {
      font-family: var(--mg-serif);
      font-size: clamp(1.75rem, 4vw, 2.75rem);
      font-weight: 700;
      letter-spacing: -0.015em;
      color: var(--mg-text);
      line-height: 1.15;
    }

    .mg-section-link {
      font-family: var(--mg-sans);
      font-size: 0.8125rem;
      font-weight: 500;
      color: var(--mg-text-muted);
      transition: color 0.2s;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .mg-section-link:hover {
      color: var(--mg-gold);
    }

    /* Warm divider between sections */
    .mg-divider {
      border: none;
      height: 1px;
      background: var(--mg-rule);
      max-width: 80rem;
      margin: 0 auto;
    }

    /* =========================================
       FEATURED + GRID LAYOUT (episode cards)
       ========================================= */
    .mg-featured-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    @media (min-width: 768px) {
      .mg-featured-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }
    }

    @media (min-width: 1024px) {
      .mg-featured-grid {
        grid-template-columns: repeat(4, 1fr);
        gap: 1.25rem;
      }
    }

    /* Episode card */
    .mg-ep-card {
      display: flex;
      flex-direction: column;
      background: var(--mg-bg-card);
      border: 1px solid var(--mg-rule);
      overflow: hidden;
      transition: all 0.35s ease;
      text-decoration: none;
      color: inherit;
      position: relative;
