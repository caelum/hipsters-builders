---
import { getCollection } from 'astro:content';
import EditorialLayout from '../../layouts/EditorialLayout.astro';
import { renderInlineMd } from '../../utils/render-inline-md';
import { topicLabel } from '../../../scripts/tag-taxonomy';

const curtas = (await getCollection('curtas'))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const podcasts = curtas.filter(c => c.data.sourceType === 'podcast');
const whatsapp = curtas.filter(c => c.data.sourceType === 'whatsapp');

const allTags = [...new Set(curtas.flatMap(c => c.data.tags))].sort();

function stripMd(text: string): string {
  return text
    .replace(/!\[[^\]]*\]\([^)]+\)/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/\*\*(.+?)\*\*/g, '$1')
    .replace(/\*(.+?)\*/g, '$1')
    .replace(/\n+/g, ' ')
    .trim();
}

function tweetFits(quote: string, speaker: string): boolean {
  const plain = stripMd(quote);
  return `\u201c${plain}\u201d \u2014 ${speaker}\nhipsters.builders/curtas`.length <= 280;
}

function tweetUrl(quote: string, speaker: string): string {
  const plain = stripMd(quote);
  return `https://twitter.com/intent/tweet?text=${encodeURIComponent(`\u201c${plain}\u201d \u2014 ${speaker}\nhipsters.builders/curtas`)}`;
}

/** Visual weight: longer quotes and quotes with images get more presence */
function weight(quote: string): 'featured' | 'standard' | 'compact' {
  if (quote.includes('![Image]')) return 'featured';
  const len = stripMd(quote).length;
  if (len > 280) return 'featured';
  if (len < 120) return 'compact';
  return 'standard';
}
---

<EditorialLayout title="Curtas" description="Quotes e insights dos podcasts e comunidades Hipsters" activeNav="curtas">

  <!-- Page header -->
  <header class="curtas-header">
    <h1 class="curtas-title">Curtas</h1>
    <p class="curtas-deck">
      As vozes da comunidade Hipsters. {curtas.length} frases
      de podcasts e conversas que valem ser lidas de novo.
    </p>
  </header>

  <!-- Filters -->
  {allTags.length > 0 && (
    <nav class="filters" id="tag-filters" aria-label="Filtrar por topico">
      <button class="filter filter--active" data-tag="all">Todos</button>
      {allTags.map(tag => (
        <button class="filter" data-tag={tag}>{topicLabel(tag)}</button>
      ))}
    </nav>
  )}

  <!-- Podcasts -->
  {podcasts.length > 0 && (
    <section class="stream" data-section>
      <div class="stream__label">
        <svg class="stream__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 18.5a6.5 6.5 0 0 0 6.5-6.5V8a6.5 6.5 0 0 0-13 0v4a6.5 6.5 0 0 0 6.5 6.5Z"/><path d="M12 18.5V22"/><path d="M8 22h8"/></svg>
        Dos Podcasts
      </div>
      <div class="masonry">
        {podcasts.map((c, i) => {
          const w = i === 0 ? 'featured' : weight(c.data.quote);
          const shareable = tweetFits(c.data.quote, c.data.speaker);
          return (
            <article class={`quote quote--${w}`} data-tags={c.data.tags.join(',')}>
              {w === 'featured' && <div class="quote__accent" aria-hidden="true" />}
              <blockquote class="quote__body">
                <p set:html={renderInlineMd(c.data.quote)} />
              </blockquote>
              <footer class="quote__foot">
                <div class="quote__who">
                  <span class="quote__speaker">{c.data.speaker}</span>
                  <span class="quote__source">{c.data.context}</span>
                </div>
                {shareable && (
                  <a class="quote__share" href={tweetUrl(c.data.quote, c.data.speaker)} target="_blank" rel="noopener" title="Compartilhar no X" aria-label="Compartilhar no X">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                  </a>
                )}
              </footer>
            </article>
          );
        })}
      </div>
    </section>
  )}

  <!-- Community -->
  {whatsapp.length > 0 && (
    <section class="stream" data-section>
      <div class="stream__label">
        <svg class="stream__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Da Comunidade
      </div>
      <div class="masonry">
        {whatsapp.map((c, i) => {
          const w = i === 0 ? 'featured' : weight(c.data.quote);
          const shareable = tweetFits(c.data.quote, c.data.speaker);
          return (
            <article class={`quote quote--${w}`} data-tags={c.data.tags.join(',')}>
              {w === 'featured' && <div class="quote__accent" aria-hidden="true" />}
              <blockquote class="quote__body">
                <p set:html={renderInlineMd(c.data.quote)} />
              </blockquote>
              <footer class="quote__foot">
                <div class="quote__who">
                  <span class="quote__speaker">{c.data.speaker}</span>
                  <span class="quote__source">{c.data.context}</span>
                </div>
                {shareable && (
                  <a class="quote__share" href={tweetUrl(c.data.quote, c.data.speaker)} target="_blank" rel="noopener" title="Compartilhar no X" aria-label="Compartilhar no X">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                  </a>
                )}
              </footer>
            </article>
          );
        })}
      </div>
    </section>
  )}

</EditorialLayout>

<style>
  /* ============================================
     CURTAS — Editorial quote wall
     Newspaper pull-quotes meet literary magazine
     ============================================ */

  /* --- Page header --- */
  .curtas-header {
    max-width: 38rem;
    padding: 1rem 0 2rem;
  }

  .curtas-title {
    font-family: var(--ed-serif);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--ed-ink);
    margin-bottom: 0.75rem;
  }

  .curtas-deck {
    font-family: var(--ed-serif);
    font-size: clamp(1rem, 2vw, 1.125rem);
    line-height: 1.6;
    color: var(--ed-ink-secondary);
  }

  /* --- Filters --- */
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--ed-rule);
    margin-bottom: 2.5rem;
  }

  .filter {
    font-family: var(--ed-sans);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--ed-ink-muted);
    background: none;
    border: none;
    padding: 0.3125rem 0.75rem;
    cursor: pointer;
    transition: color 0.12s;
    border-radius: 0;
    border-bottom: 2px solid transparent;
  }

  .filter:hover {
    color: var(--ed-ink);
  }

  .filter--active {
    color: var(--ed-ink);
    border-bottom-color: var(--ed-accent);
    font-weight: 600;
  }

  /* --- Stream (section) --- */
  .stream {
    margin-bottom: 3.5rem;
  }

  .stream[data-hidden] {
    display: none;
  }

  .stream__label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--ed-sans);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ed-ink-muted);
    margin-bottom: 2rem;
  }

  .stream__icon {
    width: 1rem;
    height: 1rem;
    opacity: 0.5;
  }

  /* --- Masonry (CSS columns) --- */
  .masonry {
    column-count: 1;
    column-gap: 2rem;
  }

  @media (min-width: 640px) {
    .masonry {
      column-count: 2;
    }
  }

  @media (min-width: 1024px) {
    .masonry {
      column-count: 3;
    }
  }

  /* --- Quote card --- */
  .quote {
    break-inside: avoid;
    margin-bottom: 2rem;
    position: relative;
  }

  .quote[data-hidden] {
    display: none;
  }

  /* Featured: full column span on mobile, accent bar */
  .quote--featured {
    padding-left: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .quote__accent {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--ed-accent);
  }

  /* --- Quote body --- */
  .quote__body {
    margin: 0;
  }

  .quote__body p {
    font-family: var(--ed-serif);
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--ed-ink);
  }

  .quote--featured .quote__body p {
    font-size: clamp(1.0625rem, 2vw, 1.1875rem);
    line-height: 1.7;
  }

  .quote--compact .quote__body p {
    font-size: 0.875rem;
  }

  /* Opening quote mark — oversized, bleeds into margin */
  .quote__body p::before {
    content: '\201c';
    font-family: var(--ed-serif);
    font-size: 2.5em;
    line-height: 0;
    vertical-align: -0.35em;
    color: var(--ed-accent);
    opacity: 0.25;
    margin-right: 0.05em;
    font-weight: 700;
  }

  .quote--featured .quote__body p::before {
    font-size: 3em;
    opacity: 0.35;
  }

  /* Inline markdown */
  .quote__body :global(strong) {
    font-weight: 600;
    color: var(--ed-ink);
  }

  .quote__body :global(em) {
    font-style: italic;
  }

  .quote__body :global(a) {
    color: var(--ed-accent);
    text-decoration: underline;
    text-decoration-color: var(--ed-rule);
    text-underline-offset: 2px;
    word-break: break-all;
    transition: text-decoration-color 0.12s;
  }

  .quote__body :global(a:hover) {
    text-decoration-color: var(--ed-accent);
  }

  .quote__body :global(.quote-img) {
    display: block;
    width: 100%;
    max-height: 18rem;
    object-fit: cover;
    margin: 0.75rem 0;
    border: 1px solid var(--ed-rule);
  }

  /* --- Quote footer --- */
  .quote__foot {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 0.875rem;
    padding-top: 0.625rem;
  }

  .quote__who {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .quote__speaker {
    font-family: var(--ed-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--ed-ink);
  }

  .quote__source {
    font-family: var(--ed-sans);
    font-size: 0.6875rem;
    color: var(--ed-ink-faint);
    letter-spacing: 0.01em;
    line-height: 1.4;
  }

  /* --- Share --- */
  .quote__share {
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ed-ink-faint);
    transition: color 0.12s;
  }

  .quote__share svg {
    width: 0.875rem;
    height: 0.875rem;
  }

  .quote__share:hover {
    color: var(--ed-accent);
  }

  @media (min-width: 640px) {
    .quote__share {
      opacity: 0;
      transition: opacity 0.12s, color 0.12s;
    }
    .quote:hover .quote__share {
      opacity: 1;
    }
  }

  /* --- Divider between sections --- */
  .stream + .stream {
    padding-top: 2.5rem;
    border-top: 1px solid var(--ed-rule);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filters = document.getElementById('tag-filters');
    if (!filters) return;

    const pills = filters.querySelectorAll<HTMLButtonElement>('.filter');
    const sections = document.querySelectorAll<HTMLElement>('[data-section]');

    function filterByTag(activeTag: string) {
      pills.forEach(pill => {
        pill.classList.toggle('filter--active', pill.dataset.tag === activeTag);
      });

      sections.forEach(section => {
        const cards = section.querySelectorAll<HTMLElement>('.quote');
        let visibleCount = 0;

        cards.forEach(card => {
          if (activeTag === 'all') {
            card.removeAttribute('data-hidden');
            visibleCount++;
          } else {
            const cardTags = (card.dataset.tags || '').split(',');
            if (cardTags.includes(activeTag)) {
              card.removeAttribute('data-hidden');
              visibleCount++;
            } else {
              card.setAttribute('data-hidden', '');
            }
          }
        });

        if (visibleCount === 0) {
          section.setAttribute('data-hidden', '');
        } else {
          section.removeAttribute('data-hidden');
        }
      });
    }

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        filterByTag(pill.dataset.tag || 'all');
      });
    });
  });
</script>
